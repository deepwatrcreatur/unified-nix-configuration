
# Global SSH settings for all hosts
Host *
    SendEnv LANG LC_*
    MACs hmac-md5,hmac-sha1
    ForwardX11 no
    ForwardAgent yes
    AddressFamily inet
    ServerAliveInterval 15
    ConnectTimeout 20
    # Hybrid known_hosts: dynamic (mutable, checked first) + NixOS-managed (read-only)
    # Dynamic file first so SSH writes new host keys there
    UserKnownHostsFile ~/.ssh/known_hosts_dynamic ~/.ssh/known_hosts_managed

