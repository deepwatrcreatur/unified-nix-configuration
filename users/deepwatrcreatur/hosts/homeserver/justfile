# users/deepwatrcreatur/hosts/homeserver/justfile
# Note: LXC containers have sudo setuid issues, use 'just switch' as root

# Build and switch (run as root, e.g., via 'su -' or SSH as root)
switch dir="/home/deepwatrcreatur/flakes/unified-nix-configuration":
  nixos-rebuild switch --flake {{dir}}#homeserver

# Build only (can run as regular user)
build dir="/home/deepwatrcreatur/flakes/unified-nix-configuration":
  nixos-rebuild build --flake {{dir}}#homeserver

# Build and activate - for LXC containers where sudo doesn't work
# Run 'just build' first, then 'just activate' as root
activate:
  ./result/bin/switch-to-configuration switch

# Test build without switching (run as root)
test dir="/home/deepwatrcreatur/flakes/unified-nix-configuration":
  nixos-rebuild test --flake {{dir}}#homeserver

# Pull latest and build (as regular user)
pull-build dir="/home/deepwatrcreatur/flakes/unified-nix-configuration":
  cd {{dir}} && git pull && just build

# Garbage collect old generations (run as root)
gc:
  nix-collect-garbage -d
